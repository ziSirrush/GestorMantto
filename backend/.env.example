PORT=3001

# Base de datos MySQL / Aiven
DB_HOST=TU_HOST_AIVEN
DB_PORT=TU_PUERTO_AIVEN
DB_USER=TU_USUARIO_AIVEN
DB_PASSWORD=TU_PASSWORD_AIVEN
DB_NAME=mydb

# Autenticacion Mantto Gestor
JWT_SECRET=CAMBIA_ESTE_SECRETO

# Corte semanal de Portafolio: domingo 12:00 hrs CDMX
PORTAFOLIO_CIERRE_SEMANAL_ENABLED=true
PORTAFOLIO_CIERRE_SEMANAL_TZ=America/Mexico_City
PORTAFOLIO_CIERRE_SEMANAL_HOUR=12
PORTAFOLIO_CIERRE_SEMANAL_MINUTE=0

# Google OAuth 2.0 / Drive
# En local:
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/google/callback
# En Azure:
# GOOGLE_OAUTH_REDIRECT_URI=https://mantto-gestor-api-a4hwfpgvbeb4gmgj.mexicocentral-01.azurewebsites.net/api/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/drive.readonly

# Clave privada y estable para cifrar tokens OAuth antes de guardarlos en MySQL.
# No debe compartirse, subirse a GitHub ni cambiarse despues de guardar tokens.
GOOGLE_TOKEN_ENCRYPTION_KEY=
